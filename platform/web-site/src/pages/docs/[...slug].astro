---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((d) => ({ params: { slug: d.id }, props: { doc: d } }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const docs = await getCollection('docs');
const catOrder = ['入门', '企业指南', '零工指南', '合规与税务', '开发者', '其他'];
const sorted = [...docs].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const grouped = catOrder
  .map((cat) => ({ cat, items: sorted.filter((d) => d.data.category === cat) }))
  .filter((g) => g.items.length);

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base title={doc.data.title} description={doc.data.description}>
  <div class="wrap docs-shell">
    <aside class="docs-nav">
      <a href="/docs" class="docs-nav-back mono">← 全部文档</a>
      {grouped.map((g) => (
        <div class="nav-group">
          <span class="nav-cat mono">{g.cat}</span>
          <ul>
            {g.items.map((d) => (
              <li>
                <a href={`/docs/${d.id}`} class={d.id === doc.id ? 'active' : ''}>{d.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>

    <article class="doc-main">
      <header class="doc-head">
        <span class="eyebrow">{doc.data.category}</span>
        <h1>{doc.data.title}</h1>
        {doc.data.updated && <p class="doc-meta mono">最后更新 · {doc.data.updated.toISOString().slice(0, 10)}</p>}
      </header>
      <div class="prose">
        <Content />
      </div>
      <footer class="doc-foot">
        <a href="/docs" class="link-arrow">返回文档中心</a>
        <a href="/about#contact" class="link-arrow">还有疑问？联系我们 →</a>
      </footer>
    </article>

    {toc.length > 0 && (
      <aside class="docs-toc">
        <span class="toc-title mono">本页目录</span>
        <ul>
          {toc.map((h) => (
            <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Base>

<style>
  .docs-shell {
    display: grid;
    grid-template-columns: 232px minmax(0, 1fr) 200px;
    gap: clamp(1.5rem, 3vw, 3rem);
    padding-block: clamp(2rem, 4vw, 3.5rem) 4rem;
    align-items: start;
  }

  /* 左侧导航 */
  .docs-nav { position: sticky; top: 88px; align-self: start; max-height: calc(100vh - 110px); overflow-y: auto; }
  .docs-nav-back { display: inline-block; font-size: 0.78rem; color: var(--ink-3); margin-bottom: 1.4rem; }
  .docs-nav-back:hover { color: var(--indigo); }
  .nav-group { margin-bottom: 1.4rem; }
  .nav-cat { display: block; font-size: 0.7rem; letter-spacing: 0.1em; color: var(--ink-3); margin-bottom: 0.5rem; text-transform: uppercase; }
  .nav-group ul { display: grid; gap: 0.1rem; }
  .nav-group a {
    display: block; font-size: var(--fs-sm); color: var(--ink-2); padding: 0.35em 0.7em;
    border-radius: var(--r-xs); border-left: 2px solid transparent; transition: all 0.18s var(--ease);
  }
  .nav-group a:hover { color: var(--ink); background: var(--paper-2); }
  .nav-group a.active { color: var(--indigo); background: color-mix(in srgb, var(--indigo) 8%, transparent); border-left-color: var(--indigo); font-weight: 600; }

  /* 正文 */
  .doc-main { min-width: 0; }
  .doc-head { padding-bottom: 1.6rem; margin-bottom: 0.4rem; border-bottom: 1px solid var(--line); }
  .doc-head h1 { font-size: clamp(1.9rem, 1.4rem + 2vw, 2.6rem); margin: 0.7rem 0 0.6rem; }
  .doc-meta { font-size: 0.76rem; color: var(--ink-3); }
  .doc-foot { margin-top: 3rem; padding-top: 1.6rem; border-top: 1px solid var(--line); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; font-size: var(--fs-sm); }

  /* 右侧 TOC */
  .docs-toc { position: sticky; top: 88px; align-self: start; }
  .toc-title { display: block; font-size: 0.7rem; letter-spacing: 0.1em; color: var(--ink-3); margin-bottom: 0.7rem; text-transform: uppercase; }
  .docs-toc ul { display: grid; gap: 0.15rem; border-left: 1px solid var(--line); }
  .docs-toc a { display: block; font-size: 0.8rem; color: var(--ink-3); padding: 0.25em 0 0.25em 0.9rem; margin-left: -1px; border-left: 2px solid transparent; transition: all 0.18s var(--ease); }
  .docs-toc a:hover { color: var(--indigo); border-left-color: var(--indigo); }
  .toc-d3 a { padding-left: 1.7rem; font-size: 0.76rem; }

  @media (max-width: 1080px) {
    .docs-shell { grid-template-columns: 220px minmax(0, 1fr); }
    .docs-toc { display: none; }
  }
  @media (max-width: 820px) {
    .docs-shell { grid-template-columns: 1fr; }
    .docs-nav {
      position: static; max-height: none; overflow: visible;
      background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--r);
      padding: 1.2rem 1.4rem; margin-bottom: 1rem;
    }
    .nav-group { margin-bottom: 1rem; }
  }
</style>
