.page-head {
  background: linear-gradient(150deg, #0F766E 0%, #0D9488 38%, #2563EB 135%);
  padding: 40rpx 32rpx 44rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}
.ph-title { color: #FFFFFF; font-size: calc(40rpx * var(--fs, 1)); font-weight: 800; }
.ph-sub { color: rgba(255, 255, 255, 0.84); font-size: calc(25rpx * var(--fs, 1)); margin-top: 10rpx; }

.wrap { padding: 24rpx 24rpx 60rpx; }

.fav-foot {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #E2E8F0;
  display: flex;
  justify-content: flex-end;
}
.fav-remove {
  font-size: calc(25rpx * var(--fs, 1));
  color: #DC2626;
  background: #FEF2F2;
  border-radius: 999rpx;
  padding: 0 28rpx;
  min-height: 64rpx;
  display: inline-flex;
  align-items: center;
}

.t-dark .page-head {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%); box-shadow: none;
}

.t-dark .fav-foot {
  border-top-color: #233149;
}

.t-dark .fav-remove {
  color: #FCA5A5; background: rgba(220, 38, 38, 0.16);
}
