.page-head {
  background: linear-gradient(150deg, #0F766E 0%, #0D9488 38%, #2563EB 135%);
  padding: 40rpx 32rpx 44rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}
.ph-title { color: #FFFFFF; font-size: calc(40rpx * var(--fs, 1)); font-weight: 800; }
.ph-sub { color: rgba(255, 255, 255, 0.84); font-size: calc(25rpx * var(--fs, 1)); margin-top: 10rpx; }

.wrap { padding: 24rpx 24rpx 60rpx; }

.verify-banner {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
}
.vb-text { color: #92400E; font-size: calc(27rpx * var(--fs, 1)); flex: 1; }
.vb-btn { color: #B45309; font-weight: 700; font-size: calc(27rpx * var(--fs, 1)); }

.section-title { font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; margin-bottom: 14rpx; display: flex; align-items: center; }
.li { color: #475569; font-size: calc(27rpx * var(--fs, 1)); line-height: 1.9; }

.guide-card { border: 1rpx solid rgba(15, 118, 110, 0.12); }
.guide-hot { border-color: #F59E0B; box-shadow: 0 14rpx 36rpx rgba(245, 158, 11, 0.16); }
.g-title { font-size: calc(32rpx * var(--fs, 1)); font-weight: 800; color: #172033; margin-bottom: 16rpx; }
.g-bars { background: #F7FAF9; border-radius: 16rpx; padding: 18rpx 22rpx; }
.g-line { display: flex; justify-content: space-between; font-size: calc(28rpx * var(--fs, 1)); color: #475569; padding: 6rpx 0; }
.g-val { font-weight: 700; color: #0F766E; }
.g-note { color: #64748B; font-size: calc(25rpx * var(--fs, 1)); line-height: 1.7; margin: 16rpx 0 20rpx; }
.g-btn { width: 100%; }

.b-tip .li { margin-bottom: 16rpx; }
.b-btn { width: 100%; }
.ledger-title { font-size: calc(28rpx * var(--fs, 1)); font-weight: 700; color: #475569; margin: 26rpx 6rpx 14rpx; }

.row-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 16rpx; }
.i-task { font-size: calc(29rpx * var(--fs, 1)); font-weight: 700; color: #172033; flex: 1; min-width: 0; }
.i-state { flex-shrink: 0; font-size: calc(23rpx * var(--fs, 1)); font-weight: 600; border-radius: 999rpx; padding: 6rpx 18rpx; }
.s-uploaded { color: #B45309; background: #FEF3C7; }
.s-verified { color: #0F766E; background: #E0F2EF; }
.s-rejected { color: #DC2626; background: #FEF2F2; }
.s-deducted { color: #2563EB; background: #E5EDFF; }
.i-meta { color: #475569; font-size: calc(26rpx * var(--fs, 1)); margin-top: 12rpx; }
.i-amt { color: #334155; font-size: calc(26rpx * var(--fs, 1)); margin-top: 8rpx; }
.i-note { color: #DC2626; font-size: calc(24rpx * var(--fs, 1)); margin-top: 8rpx; }

.t-dark .page-head {
  background: linear-gradient(130deg, #134E4A -10%, #0F766E 40%, #1D4ED8 130%); box-shadow: none;
}

.t-dark .li,
.t-dark .i-meta {
  color: #CBD5E1;
}

.t-dark .i-amt {
  color: #94A3B8;
}

.t-dark .g-title,
.t-dark .i-task {
  color: #E5E7EB;
}

.t-dark .g-bars {
  background: #0F172A;
}

.t-dark .g-line {
  color: #CBD5E1;
}

.t-dark .g-val {
  color: #5EEAD4;
}

.t-dark .g-note {
  color: #94A3B8;
}

.t-dark .s-uploaded {
  color: #FCD34D; background: rgba(180, 83, 9, 0.22);
}

.t-dark .s-verified {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}

.t-dark .s-rejected {
  color: #FCA5A5; background: rgba(220, 38, 38, 0.16);
}

.t-dark .s-deducted {
  color: #93C5FD; background: rgba(37, 99, 235, 0.18);
}
