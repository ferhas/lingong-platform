page { padding: 24rpx; }

.sec-title { font-size: calc(29rpx * var(--fs, 1)); font-weight: 700; color: #172033; display: flex; align-items: center; }
.sec-sub { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); line-height: 1.6; margin: 10rpx 0 24rpx; }

.field { margin-bottom: 24rpx; }

.picker-box {
  background: #F4F8F7;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(29rpx * var(--fs, 1));
  color: #172033;
  min-height: 84rpx;
}

.cert-btn {
  background: #FFFFFF;
  border: 2rpx dashed #B6DAD4;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(28rpx * var(--fs, 1));
  color: #0F766E;
  text-align: center;
}

.submit { margin-top: 8rpx; }

.skill-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F5F3;
}
.skill-item:last-child { border-bottom: none; padding-bottom: 4rpx; }
.skill-left { flex: 1; min-width: 0; margin-right: 16rpx; }
.skill-name { font-size: calc(29rpx * var(--fs, 1)); font-weight: 600; color: #172033; }
.skill-note { color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); margin-top: 6rpx; line-height: 1.5; }
.skill-status { font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; padding: 8rpx 20rpx; border-radius: 999rpx; flex-shrink: 0; }
.st-pending { background: #FFF7ED; color: #EA580C; }
.st-verified { background: #ECFDF5; color: #059669; }
.st-rejected { background: #FEF2F2; color: #DC2626; }

.t-dark .sec-title,
.t-dark .skill-name {
  color: #E5E7EB;
}

.t-dark .sec-sub,
.t-dark .skill-note {
  color: #94A3B8;
}

.t-dark .picker-box {
  background: #0F172A;
  color: #F8FAFC;
}

.t-dark .cert-btn {
  background: #121C2B;
  border-color: #134E4A;
  color: #5EEAD4;
}

.t-dark .skill-item {
  border-bottom-color: #233149;
}

.t-dark .st-pending {
  background: rgba(249, 115, 22, 0.16); color: #FDBA74;
}

.t-dark .st-verified {
  background: rgba(16, 185, 129, 0.16); color: #6EE7B7;
}

.t-dark .st-rejected {
  background: rgba(220, 38, 38, 0.18); color: #FCA5A5;
}
