page {
  background: linear-gradient(165deg, #14B8A6 -12%, #0F766E 22%, #2563EB 44%, #F3F7F6 44.1%);
  min-height: 100vh;
}

.hero { padding: 116rpx 48rpx 58rpx; }
.logo { color: #FFFFFF; font-size: calc(68rpx * var(--fs, 1)); font-weight: 800; letter-spacing: 4rpx; text-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.16); }
.slogan { color: rgba(255, 255, 255, 0.9); font-size: calc(30rpx * var(--fs, 1)); margin-top: 16rpx; letter-spacing: 2rpx; }

.form-card {
  margin: 0 32rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 44rpx 36rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.14);
}

.tabs {
  display: flex;
  margin-bottom: 36rpx;
  background: #F1F5F4;
  border-radius: 999rpx;
  padding: 8rpx;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: calc(30rpx * var(--fs, 1));
  color: #8A99A8;
  padding: 14rpx 0;
  border-radius: 999rpx;
  transition: all 0.2s ease;
}
.tab-active {
  color: #0F766E;
  font-weight: 700;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.08);
}

.field { margin-bottom: 28rpx; }

.submit { margin-top: 12rpx; }
.tip { text-align: center; color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); margin-top: 24rpx; }

.divider {
  display: flex;
  align-items: center;
  margin: 28rpx 0 8rpx;
}
.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #E4ECE9;
}
.divider-text { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); padding: 0 20rpx; }

.wechat-btn {
  margin-top: 20rpx;
  background: #07C160;
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: calc(30rpx * var(--fs, 1));
  font-weight: 700;
  min-height: 88rpx;
  box-shadow: 0 12rpx 26rpx rgba(7, 193, 96, 0.24);
}
.wechat-icon {
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  display: inline-block;
  text-align: center;
  vertical-align: middle;
  font-size: calc(20rpx * var(--fs, 1));
  margin-right: 10rpx;
  font-weight: 800;
}

.mock-btn {
  margin-top: 20rpx;
  background: #FFFFFF;
  color: #0F766E;
  border: 2rpx dashed #0F766E;
  border-radius: 999rpx;
  font-size: calc(28rpx * var(--fs, 1));
  font-weight: 700;
  min-height: 84rpx;
}
.mock-tip {
  text-align: center;
  color: #94A3B8;
  font-size: calc(24rpx * var(--fs, 1));
  margin-top: 12rpx;
}

.agree-row {
  display: flex;
  align-items: center;
  margin: 24rpx 4rpx 4rpx;
}
.agree-box {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #B6DAD4;
  border-radius: 10rpx;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: calc(24rpx * var(--fs, 1));
  flex-shrink: 0;
}
.agree-on { background: #0F766E; border-color: #0F766E; }
.agree-text { color: #64748B; font-size: calc(26rpx * var(--fs, 1)); line-height: 1.55; }
.agree-link { color: #0F766E; font-weight: 600; }

.bind-title { font-size: calc(36rpx * var(--fs, 1)); font-weight: 700; }
.bind-sub { color: #8A99A8; font-size: calc(28rpx * var(--fs, 1)); margin: 10rpx 0 28rpx; }
.back-link { text-align: center; color: #0F766E; font-size: calc(28rpx * var(--fs, 1)); font-weight: 600; margin-top: 24rpx; }

@media (prefers-color-scheme: dark) {
  page {
    background: linear-gradient(165deg, #134E4A -12%, #0F766E 22%, #1D4ED8 44%, #0F172A 44.1%);
  }

  .tabs {
    background: #0F172A;
  }

  .form-card {
    background: #121C2B;
    border-color: #233149;
    box-shadow: none;
  }

  .tab,
  .tip,
  .divider-text,
  .bind-sub {
    color: #94A3B8;
  }

  .agree-link,
  .back-link {
    color: #5EEAD4;
  }

  .tab-active {
    color: #5EEAD4;
    background: #1E293B;
    box-shadow: none;
  }

  .field-label,
  .agree-text {
    color: #CBD5E1;
  }

  .bind-title {
    color: #E5E7EB;
  }

  .divider::before,
  .divider::after {
    background: #233149;
  }

  .agree-box {
    border-color: #134E4A;
  }

  .agree-on {
    background: #0F766E;
    border-color: #0F766E;
  }

  .mock-btn {
    background: #121C2B;
    color: #5EEAD4;
    border-color: #5EEAD4;
  }

  .mock-tip {
    color: #64748B;
  }
}
