page { padding: 24rpx 24rpx 80rpx; }

.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-title { font-size: calc(32rpx * var(--fs, 1)); font-weight: 700; flex: 1; margin-right: 16rpx; color: #172033; line-height: 1.45; }
.status { font-size: calc(24rpx * var(--fs, 1)); padding: 8rpx 20rpx; border-radius: 999rpx; flex-shrink: 0; font-weight: 600; }
.status-open { background: #FFF7ED; color: #EA580C; }
.status-pending_user { background: #FEF2F2; color: #DC2626; }
.status-pending_agent { background: #E0F2FE; color: #0284C7; }
.status-resolved { background: #ECFDF5; color: #059669; }
.status-closed { background: #F1F5F9; color: #64748B; }
.card-meta { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin-top: 8rpx; }

/* 对话流 */
.msg-list { margin-bottom: 22rpx; }
.msg-row { display: flex; margin-bottom: 24rpx; }
.msg-row.msg-mine { flex-direction: row-reverse; }
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 50%;
  text-align: center;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 700;
  flex-shrink: 0;
}
.avatar-agent { background: #E0F2FE; color: #0284C7; margin-right: 16rpx; }
.avatar-mine { background: #E7F4F1; color: #0F766E; margin-left: 16rpx; }
.msg-body { max-width: 76%; display: flex; flex-direction: column; }
.msg-mine .msg-body { align-items: flex-end; }
.msg-bubble {
  background: #FFFFFF;
  border-radius: 6rpx 22rpx 22rpx 22rpx;
  padding: 18rpx 24rpx;
  font-size: calc(28rpx * var(--fs, 1));
  color: #334155;
  line-height: 1.65;
  word-break: break-all;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}
.bubble-mine {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  border-radius: 22rpx 6rpx 22rpx 22rpx;
}
.msg-time { color: #B0BCC9; font-size: calc(22rpx * var(--fs, 1)); margin-top: 8rpx; }

.act-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}
.btn-send {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: calc(27rpx * var(--fs, 1));
  min-height: 64rpx;
}
.btn-send[disabled] { background: #C2D2CF; color: #FFFFFF; }
.btn-close {
  background: #FFFFFF;
  color: #64748B;
  border: 1rpx solid #E2E8F0;
  border-radius: 999rpx;
  font-size: calc(26rpx * var(--fs, 1));
  min-height: 64rpx;
}

.rate-card { text-align: center; }
.rate-title { font-size: calc(29rpx * var(--fs, 1)); font-weight: 700; color: #172033; margin-bottom: 18rpx; }
.star-row { display: flex; justify-content: center; gap: 20rpx; }
.star { font-size: calc(60rpx * var(--fs, 1)); color: #E2E8F0; line-height: 1; }
.star:active { color: #F59E0B; }
.rated-tip { text-align: center; color: #D97706; font-size: calc(27rpx * var(--fs, 1)); padding: 12rpx 0 30rpx; }

@media (prefers-color-scheme: dark) {
  .card-title,
  .rate-title {
    color: #E5E7EB;
  }

  .card-meta {
    color: #94A3B8;
  }

  .status-open { background: rgba(249, 115, 22, 0.16); color: #FDBA74; }
  .status-pending_user { background: rgba(220, 38, 38, 0.18); color: #FCA5A5; }
  .status-pending_agent { background: rgba(2, 132, 199, 0.18); color: #7DD3FC; }
  .status-resolved { background: rgba(16, 185, 129, 0.16); color: #6EE7B7; }
  .status-closed { background: #1E293B; color: #94A3B8; }

  .msg-bubble {
    background: #121C2B;
    color: #CBD5E1;
    box-shadow: none;
  }

  .bubble-mine {
    background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
    color: #FFFFFF;
  }

  .avatar-agent { background: rgba(2, 132, 199, 0.18); color: #7DD3FC; }
  .avatar-mine { background: rgba(20, 184, 166, 0.16); color: #5EEAD4; }

  .btn-close {
    background: #121C2B;
    border-color: #233149;
    color: #94A3B8;
  }

  .star { color: #334155; }
}
