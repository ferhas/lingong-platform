.profile {
  background: linear-gradient(150deg, #0F766E 0%, #0D9488 38%, #2563EB 135%);
  padding: 52rpx 32rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}
.profile::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}
.profile::before {
  content: '';
  position: absolute;
  left: -60rpx;
  bottom: -120rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  color: #FFFFFF;
  font-size: calc(44rpx * var(--fs, 1));
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.16);
}
.profile-info { position: relative; z-index: 1; min-width: 0; flex: 1; }
.profile-kicker { color: rgba(255, 255, 255, 0.74); font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; margin-bottom: 4rpx; letter-spacing: 2rpx; }
.name { color: #FFFFFF; font-size: calc(36rpx * var(--fs, 1)); font-weight: 800; display: flex; align-items: center; flex-wrap: wrap; gap: 8rpx; }
.verified, .unverified {
  font-size: calc(22rpx * var(--fs, 1));
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.verified { background: rgba(255, 255, 255, 0.25); border: 1rpx solid rgba(255, 255, 255, 0.3); }
.unverified { background: rgba(239, 68, 68, 0.9); }
.role { color: rgba(255, 255, 255, 0.84); font-size: calc(27rpx * var(--fs, 1)); margin-top: 10rpx; }

.stats {
  margin: -36rpx 24rpx 24rpx;
  position: relative;
  z-index: 2;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.08);
  transition: transform 0.15s ease;
}
.stat-num { font-size: calc(44rpx * var(--fs, 1)); font-weight: 800; color: #0F766E; }
.stat-label { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); margin-top: 6rpx; }
.stat-link {
  color: #0F766E;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 600;
  background: #E0F2EF;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
}

/* —— 信用分卡片 —— */
.credit-card {
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03), 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
}
.credit-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.credit-score-wrap { display: flex; align-items: baseline; gap: 12rpx; }
.credit-score { font-size: calc(52rpx * var(--fs, 1)); font-weight: 800; color: #0F766E; }
.credit-label { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); }
.credit-grade {
  font-size: calc(25rpx * var(--fs, 1));
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}
.grade-premium { background: #ECFDF5; color: #059669; }
.grade-good { background: #E0F2FE; color: #0284C7; }
.grade-normal { background: #FEF3C7; color: #D97706; }
.grade-limited { background: #FEF2F2; color: #DC2626; }
.credit-stats {
  display: flex;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #F0F5F3;
}
.credit-stat { flex: 1; text-align: center; }
.cs-num { font-size: calc(32rpx * var(--fs, 1)); font-weight: 700; color: #172033; }
.cs-label { color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); margin-top: 4rpx; }
.skill-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}
.skill-badge {
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(23rpx * var(--fs, 1));
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}
.badge-warn {
  background: #FEF3C7;
  color: #D97706;
}

.verify-banner {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border: 1rpx solid #FDE68A;
  border-radius: 20rpx;
  padding: 24rpx 26rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.vb-text { color: #B45309; font-size: calc(27rpx * var(--fs, 1)); flex: 1; }
.vb-btn {
  color: #FFFFFF;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 600;
  background: #D97706;
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.locked-banner {
  margin: 0 24rpx 24rpx;
  background: #FEF2F2;
  color: #B91C1C;
  border: 1rpx solid #FECACA;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(28rpx * var(--fs, 1));
  line-height: 1.6;
}

.menu-list {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03), 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F5F3;
}
.menu-item:last-child { border-bottom: none; }
.menu-hover { background: #FAFCFB; }
.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(24rpx * var(--fs, 1));
  font-weight: 800;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.menu-item:nth-child(1) .menu-icon { background: #E0F2FE; color: #0284C7; }
.menu-item:nth-child(2) .menu-icon { background: #E7F4F1; color: #0F766E; }
.menu-item:nth-child(3) .menu-icon { background: #FEF3C7; color: #D97706; }
.menu-item:nth-child(4) .menu-icon { background: #EDE9FE; color: #7C3AED; }
.menu-item:nth-child(5) .menu-icon { background: #FCE7F3; color: #DB2777; }
.menu-item:nth-child(6) .menu-icon { background: #FFEDD5; color: #EA580C; }
.menu-item:nth-child(7) .menu-icon { background: #E2E8F0; color: #475569; }
.menu-item:nth-child(8) .menu-icon { background: #CFFAFE; color: #0891B2; }
.menu-item:nth-child(9) .menu-icon { background: #FEF2F2; color: #DC2626; }
.menu-item:nth-child(10) .menu-icon { background: #E0F2FE; color: #0284C7; }
.menu-item:nth-child(11) .menu-icon { background: #DCFCE7; color: #16A34A; }
.menu-item:nth-child(12) .menu-icon { background: #EDE9FE; color: #7C3AED; }
.menu-item:nth-child(13) .menu-icon { background: #E2E8F0; color: #475569; }
.menu-label { flex: 1; font-size: calc(28rpx * var(--fs, 1)); color: #172033; }
.menu-badge {
  background: #ECFDF5;
  color: #059669;
  font-size: calc(23rpx * var(--fs, 1));
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
}
.menu-unread {
  background: #DC2626;
  color: #FFFFFF;
  font-size: calc(23rpx * var(--fs, 1));
  min-width: 34rpx;
  text-align: center;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
  box-shadow: 0 4rpx 10rpx rgba(220, 38, 38, 0.3);
}
.edit-hint { font-size: calc(22rpx * var(--fs, 1)); opacity: 0.82; font-weight: 500; }
.menu-arrow { color: #CBD5E1; font-size: calc(32rpx * var(--fs, 1)); }

.logout {
  margin: 32rpx 24rpx 180rpx;
  background: #FFFFFF;
  color: #EF4444;
  text-align: center;
  border-radius: 999rpx;
  padding: 26rpx 0;
  font-size: calc(28rpx * var(--fs, 1));
  font-weight: 600;
  border: 1rpx solid rgba(239, 68, 68, 0.16);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
  transition: transform 0.15s ease;
}

/* —— 字体大小设置 —— */
.fs-card {
  margin: 24rpx 24rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03), 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
}
.fs-head { margin-bottom: 22rpx; }
.fs-title { font-size: calc(30rpx * var(--fs, 1)); font-weight: 800; color: #172033; }
.fs-cur { margin-left: auto; color: #0F766E; font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; }
.fs-seg { display: flex; gap: 14rpx; }
.fs-opt {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #F4F8F7;
  color: #475569;
  font-size: calc(28rpx * var(--fs, 1));
  font-weight: 600;
  border: 2rpx solid transparent;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}
.fs-opt-on { background: #E0F2EF; color: #0F766E; border-color: #0F766E; }
.fs-opt-hover { opacity: 0.82; }
.fs-tip { margin-top: 18rpx; color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); line-height: 1.6; }

.t-dark .profile {
  background: linear-gradient(130deg, #134E4A -10%, #0F766E 40%, #1D4ED8 130%);
  box-shadow: none;
}

.t-dark .stats,
.t-dark .menu-list,
.t-dark .logout {
  background: #121C2B;
  border-color: #233149;
  box-shadow: none;
}

.t-dark .stat-num {
  color: #5EEAD4;
}

.t-dark .menu-label {
  color: #E5E7EB;
}

.t-dark .stat-label,
.t-dark .menu-arrow {
  color: #94A3B8;
}

.t-dark .stat-link {
  color: #5EEAD4;
  background: rgba(20, 184, 166, 0.14);
}

.t-dark .menu-hover {
  background: #0F172A;
}

.t-dark .verify-banner {
  background: rgba(180, 83, 9, 0.18);
  border-color: rgba(251, 191, 36, 0.26);
}

.t-dark .vb-text {
  color: #FCD34D;
}

.t-dark .vb-btn {
  background: rgba(217, 119, 6, 0.85);
  color: #FFFBEB;
}

.t-dark .locked-banner {
  background: rgba(185, 28, 28, 0.18);
  color: #FCA5A5;
  border-color: rgba(248, 113, 113, 0.24);
}

.t-dark .menu-item {
  border-bottom-color: #233149;
}

.t-dark .menu-icon {
  background: rgba(20, 184, 166, 0.16) !important;
  color: #5EEAD4 !important;
}

.t-dark .menu-badge {
  background: rgba(16, 185, 129, 0.16);
  color: #6EE7B7;
}

.t-dark .logout {
  color: #FCA5A5;
  border-color: #233149;
}

.t-dark .credit-card {
  background: #121C2B;
  border-color: #233149;
  box-shadow: none;
}

.t-dark .credit-score {
  color: #5EEAD4;
}

.t-dark .cs-num {
  color: #E5E7EB;
}

.t-dark .credit-stats {
  border-top-color: #233149;
}

.t-dark .grade-premium {
  background: rgba(16, 185, 129, 0.16); color: #6EE7B7;
}

.t-dark .grade-good {
  background: rgba(2, 132, 199, 0.18); color: #7DD3FC;
}

.t-dark .grade-normal {
  background: rgba(217, 119, 6, 0.18); color: #FCD34D;
}

.t-dark .grade-limited {
  background: rgba(220, 38, 38, 0.18); color: #FCA5A5;
}

.t-dark .skill-badge {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
}

.t-dark .badge-warn {
  background: rgba(217, 119, 6, 0.18);
  color: #FCD34D;
}

.t-dark .fs-card {
  background: #121C2B;
  border-color: #233149;
  box-shadow: none;
}

.t-dark .fs-title {
  color: #E5E7EB;
}

.t-dark .fs-cur {
  color: #5EEAD4;
}

.t-dark .fs-opt {
  background: #0F172A;
  color: #CBD5E1;
}

.t-dark .fs-opt-on {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
  border-color: #134E4A;
}

.t-dark .fs-tip {
  color: #94A3B8;
}
