.detail-header {
  background: linear-gradient(150deg, #0F766E 0%, #0D9488 38%, #2563EB 135%);
  padding: 38rpx 32rpx 46rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}
.detail-header::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -110rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}
.detail-header::before {
  content: '';
  position: absolute;
  left: -70rpx;
  bottom: -120rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.detail-kicker {
  position: relative;
  z-index: 1;
  color: rgba(255, 255, 255, 0.76);
  font-size: calc(24rpx * var(--fs, 1));
  font-weight: 600;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.fav-btn {
  color: #FFFFFF;
  font-size: calc(25rpx * var(--fs, 1));
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  padding: 0 24rpx;
  min-height: 56rpx;
  display: inline-flex;
  align-items: center;
}
.fav-on { color: #FDE68A; border-color: rgba(253, 230, 138, 0.6); }
.d-title { position: relative; z-index: 1; color: #FFFFFF; font-size: calc(38rpx * var(--fs, 1)); font-weight: 700; line-height: 1.45; }
.d-tags { position: relative; z-index: 1; display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.d-tag {
  font-size: calc(23rpx * var(--fs, 1));
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 8rpx;
  padding: 5rpx 16rpx;
}
.ins-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10rpx; }
.ins-plan { font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; color: #0F766E; }
.ins-free { font-size: calc(24rpx * var(--fs, 1)); color: #0F766E; background: #E7F4F1; border-radius: 999rpx; padding: 6rpx 18rpx; }
.ins-cover { font-size: calc(27rpx * var(--fs, 1)); }
.d-price-row { margin-top: 20rpx; position: relative; z-index: 1; }
.d-price { position: relative; z-index: 1; color: #FDE68A; font-size: calc(52rpx * var(--fs, 1)); font-weight: 800; text-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.16); }
.d-unit { color: rgba(255, 255, 255, 0.88); font-size: calc(28rpx * var(--fs, 1)); margin-left: 16rpx; }
.d-meta { position: relative; z-index: 1; color: rgba(255, 255, 255, 0.84); font-size: calc(26rpx * var(--fs, 1)); margin-top: 14rpx; }

page { padding: 0 0 220rpx; }
.card { margin: 0 24rpx 20rpx; }
.section-title { font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; margin-bottom: 14rpx; display: flex; align-items: center; }
.section-sub { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin: -6rpx 0 12rpx; }
.section-body { color: #475569; font-size: calc(29rpx * var(--fs, 1)); line-height: 1.85; }

.income-row {
  display: flex;
  justify-content: space-between;
  font-size: calc(29rpx * var(--fs, 1));
  padding: 12rpx 0;
  color: #334155;
}
.income-row.gray { color: #8A99A8; }
.income-row.net {
  font-weight: 800;
  color: #0F766E;
  font-size: calc(31rpx * var(--fs, 1));
  margin-top: 10rpx;
  background: #E7F4F1;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}
.income-tip {
  color: #64748B;
  font-size: calc(25rpx * var(--fs, 1));
  margin-top: 14rpx;
  line-height: 1.7;
  background: #F7FAF9;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(20rpx);
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -10rpx 32rpx rgba(15, 23, 42, 0.08);
  border-radius: 32rpx 32rpx 0 0;
}
.footer-note { text-align: center; color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin-bottom: 12rpx; }
.verify-btn { background: linear-gradient(135deg, #D97706 0%, #EA580C 100%); }
.withdraw-apply {
  margin-top: 16rpx;
  background: #FFFFFF;
  color: #64748B;
  border: 1rpx solid #D8E0E5;
  border-radius: 999rpx;
  font-size: calc(28rpx * var(--fs, 1));
  min-height: 80rpx;
}

.t-dark .detail-header {
  background: linear-gradient(130deg, #134E4A -10%, #0F766E 40%, #1D4ED8 130%);
  box-shadow: none;
}

.t-dark .section-body {
  color: #CBD5E1;
}

.t-dark .income-row.gray,
.t-dark .section-sub,
.t-dark .income-tip,
.t-dark .footer-note {
  color: #94A3B8;
}

.t-dark .income-row {
  color: #CBD5E1;
}

.t-dark .income-row.net {
  color: #5EEAD4;
  background: rgba(20, 184, 166, 0.12);
}

.t-dark .income-tip {
  background: #0F172A;
}

.t-dark .ins-plan {
  color: #5EEAD4;
}

.t-dark .ins-free {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}

.t-dark .footer {
  background: rgba(18, 28, 43, 0.94);
  box-shadow: none;
}

.t-dark .withdraw-apply {
  background: #121C2B;
  color: #94A3B8;
  border-color: #233149;
}
