<page-meta page-style="{{pageStyle}}"></page-meta>
<view class="theme-root {{themeClass}}">
<block wx:if="{{task}}">
  <view class="detail-header">
    <view class="detail-kicker">
      <text>任务详情</text>
      <text class="fav-btn {{task.favorited ? 'fav-on' : ''}}" catchtap="onToggleFav">{{task.favorited ? '★ 已收藏' : '☆ 收藏'}}</text>
    </view>
    <view class="d-title">{{task.title}}</view>
    <view class="d-tags">
      <text class="d-tag d-tag-city">📍 {{task.city}}</text>
      <text class="d-tag">{{task.category}}</text>
      <text wx:if="{{task.trade}}" class="d-tag d-tag-trade">{{task.trade}}</text>
    </view>
    <view class="d-price-row">
      <text class="d-price">¥{{task.subPrice || task.price}}</text>
      <text class="d-unit">{{task.payMethod}} · 税前报酬</text>
    </view>
    <view class="d-meta">{{task.companyName}} · 截止 {{task.deadline}} · {{task.applicants}}人已报名</view>
  </view>

  <view class="card">
    <view class="section-title"><text class="title-mark"></text>任务描述</view>
    <view class="section-body">{{task.description}}</view>
  </view>

  <view class="card" wx:if="{{task.standard}}">
    <view class="section-title"><text class="title-mark"></text>交付标准</view>
    <view class="section-body">{{task.standard}}</view>
  </view>

  <view class="card">
    <view class="section-title"><text class="title-mark"></text>收入预估</view>
    <view class="section-sub">按当前累计预扣口径试算，实际以结算时为准</view>
    <view class="income-row"><text>分包报酬（税前）</text><text>¥{{task.estimate.gross}}</text></view>
    <block wx:if="{{task.estimate.subjectType === 'soletrader'}}">
      <view class="income-row net"><text>预计到手</text><text>¥{{task.estimate.net}}</text></view>
      <view class="income-tip">您是个体工商户（B线）：经营所得自行申报，平台不代扣个税；结算前需向平台开具发票。</view>
    </block>
    <block wx:else>
      <view class="income-row gray"><text>预扣个税（平台代扣代缴）</text><text>-¥{{task.estimate.tax}}</text></view>
      <view class="income-row gray" wx:if="{{task.estimate.vat > 0}}"><text>代办增值税及附加</text><text>-¥{{task.estimate.vat}}</text></view>
      <view class="income-row net"><text>预计到手</text><text>¥{{task.estimate.net}}</text></view>
      <view class="income-tip">月销售额达免征额前免征增值税 · 实际税额以结算时累计预扣计算为准</view>
    </block>
  </view>

  <view class="card" wx:if="{{task.insurance}}">
    <view class="section-title"><text class="title-mark"></text>接单保障</view>
    <view class="ins-row">
      <text class="ins-plan">{{task.insurance.plan}}</text>
      <text class="ins-free">保费平台承担 · 免费</text>
    </view>
    <view class="section-body ins-cover">{{task.insurance.coverage}}</view>
    <view class="income-tip">接单即自动投保意外险（接单生效、交付终止）；如遇意外可在「我的保险」一键报案。</view>
  </view>

  <view class="safe-pad"></view>

  <view class="footer">
    <view class="footer-note">报名经录用后自动签署《分包工单》并按单投保意外险</view>
    <button wx:if="{{!verified}}" class="btn-primary verify-btn" hover-class="btn-hover" bindtap="goVerify">先去实名认证（认证后可接单）</button>
    <button
      wx:else
      class="btn-primary"
      hover-class="btn-hover"
      disabled="{{task.applied || task.status !== 'recruiting' || task.expired || applying}}"
      bindtap="onApply"
    >{{task.applied ? '已报名，等待企业确认' : (task.expired ? '已过截止日期' : (task.status === 'recruiting' ? '立即报名' : '已停止报名'))}}</button>
    <button
      wx:if="{{verified && task.applied && task.status === 'recruiting'}}"
      style="margin-top:16rpx;background:#fff;color:#888;border:1rpx solid #ddd;"
      hover-class="btn-hover"
      disabled="{{applying}}"
      bindtap="onWithdrawApply"
    >取消报名</button>
  </view>
</block>
</view>
