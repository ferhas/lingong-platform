.deliver-hero {
  padding: 40rpx 36rpx 28rpx;
}
.hero-kicker {
  color: #0F766E;
  font-size: calc(24rpx * var(--fs, 1));
  font-weight: 600;
}
.hero-title {
  font-size: calc(40rpx * var(--fs, 1));
  font-weight: 700;
  color: #172033;
  margin-top: 6rpx;
}
.hero-meta {
  color: #64748B;
  font-size: calc(26rpx * var(--fs, 1));
  margin-top: 8rpx;
}

.form-card {
  margin: 0 28rpx;
  padding: 28rpx 28rpx 8rpx;
}

.standard-tip {
  background: #F0FBF8;
  border: 1rpx solid #BBE7DF;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  font-size: calc(26rpx * var(--fs, 1));
  color: #0F766E;
  line-height: 1.6;
  margin-bottom: 24rpx;
}
.standard-tip .tip-mark {
  display: inline-block;
  font-weight: 700;
  margin-right: 12rpx;
}

.field {
  margin-bottom: 28rpx;
}
.field-label .req {
  color: #E11D48;
  margin-left: 6rpx;
}
.field-label .unit {
  color: #94A3B8;
  font-weight: 400;
}

.picker-box {
  width: 100%;
  background: #F4F8F7;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(30rpx * var(--fs, 1));
  color: #172033;
  min-height: 84rpx;
  box-sizing: border-box;
}
.dt-row {
  display: flex;
  gap: 16rpx;
}
.dt-row picker {
  flex: 1;
}

.up-hint {
  color: #94A3B8;
  font-weight: 400;
}
.up-tip {
  color: #94A3B8;
  font-size: calc(24rpx * var(--fs, 1));
  margin-bottom: 12rpx;
}
.file-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.file-chip2 {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #F4F8F7;
  border: 1rpx solid #DCEAE7;
  border-radius: 14rpx;
  padding: 12rpx 18rpx;
  max-width: 100%;
}
.fc-name {
  font-size: calc(26rpx * var(--fs, 1));
  color: #334155;
  max-width: 360rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.fc-del {
  color: #94A3B8;
  font-size: calc(26rpx * var(--fs, 1));
}
.file-add {
  background: #FFFFFF;
  border: 1rpx dashed #0F766E;
  color: #0F766E;
  border-radius: 14rpx;
  padding: 12rpx 24rpx;
  font-size: calc(26rpx * var(--fs, 1));
}

.submit-bar {
  padding: 16rpx 28rpx 48rpx;
}
.submit-btn {
  width: 100%;
}

.loading {
  text-align: center;
  color: #94A3B8;
  padding: 80rpx 0;
  font-size: calc(28rpx * var(--fs, 1));
}
