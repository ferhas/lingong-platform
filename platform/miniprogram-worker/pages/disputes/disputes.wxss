.page-hero {
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.page-hero::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.hero-kicker { color: rgba(255, 255, 255, 0.78); font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; letter-spacing: 2rpx; }
.hero-title { font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; margin-top: 4rpx; }
.hero-count {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  padding: 12rpx 26rpx;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 700;
}

.dispute-list { padding: 20rpx 24rpx 80rpx; }

.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-title { font-size: calc(31rpx * var(--fs, 1)); font-weight: 700; flex: 1; margin-right: 16rpx; color: #172033; line-height: 1.45; }
.status { font-size: calc(24rpx * var(--fs, 1)); padding: 8rpx 20rpx; border-radius: 999rpx; flex-shrink: 0; font-weight: 600; }
.status-negotiating { background: #FFF7ED; color: #EA580C; }
.status-arbitrating { background: #EDE9FE; color: #7C3AED; }
.status-ruled { background: #E0F2FE; color: #0284C7; }
.status-executed { background: #ECFDF5; color: #059669; }
.status-closed { background: #F1F5F9; color: #64748B; }
.status-withdrawn { background: #F1F5F9; color: #64748B; }
.status-escalated { background: #FEF2F2; color: #DC2626; }

.card-meta { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin-top: 8rpx; }
.claim-text {
  color: #475569;
  font-size: calc(27rpx * var(--fs, 1));
  line-height: 1.6;
  margin-top: 14rpx;
  background: #F7FAF9;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
}
.claim-amount { color: #D97706; font-size: calc(27rpx * var(--fs, 1)); font-weight: 700; }
.deadline { color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); margin-left: auto; }
.ruling-flag { color: #0F766E; font-size: calc(26rpx * var(--fs, 1)); font-weight: 600; margin-left: auto; }

.t-dark .page-hero {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%);
  box-shadow: none;
}

.t-dark .card-title {
  color: #E5E7EB;
}

.t-dark .card-meta,
.t-dark .deadline {
  color: #94A3B8;
}

.t-dark .claim-text {
  background: #0F172A;
  color: #CBD5E1;
}

.t-dark .status-negotiating {
  background: rgba(249, 115, 22, 0.16); color: #FDBA74;
}

.t-dark .status-arbitrating {
  background: rgba(124, 58, 237, 0.18); color: #C4B5FD;
}

.t-dark .status-ruled {
  background: rgba(2, 132, 199, 0.18); color: #7DD3FC;
}

.t-dark .status-executed {
  background: rgba(16, 185, 129, 0.16); color: #6EE7B7;
}

.t-dark .status-closed,
.t-dark .status-withdrawn {
  background: #1E293B; color: #94A3B8;
}

.t-dark .status-escalated {
  background: rgba(220, 38, 38, 0.18); color: #FCA5A5;
}

.t-dark .ruling-flag {
  color: #5EEAD4;
}
