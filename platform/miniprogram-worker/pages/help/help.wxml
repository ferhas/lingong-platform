<page-meta page-style="{{pageStyle}}"></page-meta>
<view class="theme-root {{themeClass}}">
<view class="help-header">
  <view class="help-title">有什么可以帮您？</view>
  <view class="search">
    <view class="search-icon">搜</view>
    <input
      class="search-input"
      placeholder="搜索问题，如：提现、发票"
      confirm-type="search"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onSearch"
    />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>
</view>

<view class="help-list">
  <view wx:if="{{!loading && !total}}" class="empty">没有找到相关内容，换个关键词试试</view>

  <view wx:for="{{groups}}" wx:for-item="group" wx:key="category" class="card">
    <view class="group-title"><text class="title-mark"></text>{{group.category}}</view>
    <view
      wx:for="{{group.items}}"
      wx:key="id"
      class="article-item"
      hover-class="article-hover"
      hover-stay-time="80"
      data-id="{{item.id}}"
      bindtap="onTapArticle"
    >
      <text class="article-title">{{item.title}}</text>
      <text class="article-arrow">›</text>
    </view>
  </view>

  <view class="contact-tip" bindtap="goTickets">没有解决您的问题？联系在线客服 ›</view>
</view>
</view>
