.doc {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 36rpx 32rpx;
  border: 1rpx solid #E4ECE9;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}
.doc-title { font-size: calc(36rpx * var(--fs, 1)); font-weight: 800; color: #172033; }
.doc-meta { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); margin: 12rpx 0 28rpx; }
.doc-content {
  display: block;
  font-size: calc(30rpx * var(--fs, 1));
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
}

.contact-tip {
  text-align: center;
  color: #0F766E;
  font-size: calc(27rpx * var(--fs, 1));
  font-weight: 600;
  padding: 8rpx 0 50rpx;
}

.t-dark .doc {
  background: #121C2B;
  border-color: #233149;
  box-shadow: none;
}

.t-dark .doc-title {
  color: #E5E7EB;
}

.t-dark .doc-meta {
  color: #94A3B8;
}

.t-dark .doc-content {
  color: #CBD5E1;
}

.t-dark .contact-tip {
  color: #5EEAD4;
}
