.help-header {
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  padding: 44rpx 32rpx 40rpx;
  border-radius: 0 0 36rpx 36rpx;
}
.help-title { color: #FFFFFF; font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; margin-bottom: 24rpx; }

.search {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 10rpx 12rpx 10rpx 20rpx;
}
.search-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(22rpx * var(--fs, 1));
  font-weight: 700;
  flex-shrink: 0;
}
.search-input { flex: 1; font-size: calc(28rpx * var(--fs, 1)); padding: 0 18rpx; color: #172033; }
.search-btn {
  flex-shrink: 0;
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 600;
  border-radius: 999rpx;
  padding: 12rpx 30rpx;
}

.help-list { padding: 24rpx 24rpx 80rpx; }

.group-title {
  font-size: calc(29rpx * var(--fs, 1));
  font-weight: 700;
  color: #172033;
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.article-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 4rpx;
  border-bottom: 1rpx solid #F0F5F3;
}
.article-item:last-child { border-bottom: none; padding-bottom: 4rpx; }
.article-hover { background: #FAFCFB; }
.article-title { flex: 1; font-size: calc(28rpx * var(--fs, 1)); color: #334155; line-height: 1.5; margin-right: 16rpx; }
.article-arrow { color: #CBD5E1; font-size: calc(32rpx * var(--fs, 1)); }

.contact-tip {
  text-align: center;
  color: #0F766E;
  font-size: calc(27rpx * var(--fs, 1));
  font-weight: 600;
  padding: 16rpx 0 30rpx;
}

.t-dark .help-header {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%);
}

.t-dark .search {
  background: #121C2B;
}

.t-dark .search-input {
  color: #F8FAFC;
}

.t-dark .search-icon {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
}

.t-dark .group-title {
  color: #E5E7EB;
}

.t-dark .article-item {
  border-bottom-color: #233149;
}

.t-dark .article-hover {
  background: #0F172A;
}

.t-dark .article-title {
  color: #CBD5E1;
}

.t-dark .contact-tip {
  color: #5EEAD4;
}
