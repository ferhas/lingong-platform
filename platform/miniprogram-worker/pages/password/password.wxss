page { padding: 24rpx; }

.security-hero {
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  border-radius: 28rpx;
  padding: 36rpx 30rpx;
  color: #FFFFFF;
  margin-bottom: 22rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.security-hero::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.hero-kicker { color: rgba(255, 255, 255, 0.76); font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; }
.hero-title { font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; margin-top: 6rpx; }
.hero-sub { color: rgba(255, 255, 255, 0.84); font-size: calc(27rpx * var(--fs, 1)); line-height: 1.65; margin-top: 8rpx; }

.field { margin-bottom: 26rpx; }
.field:last-child { margin-bottom: 6rpx; }

.tip { color: #64748B; font-size: calc(26rpx * var(--fs, 1)); margin: 8rpx 8rpx 28rpx; }
.submit { margin: 0 8rpx; }

.t-dark .security-hero {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%);
  box-shadow: none;
}

.t-dark .field-label {
  color: #CBD5E1;
}

.t-dark .tip {
  color: #94A3B8;
}
