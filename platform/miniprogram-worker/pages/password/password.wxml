<page-meta page-style="{{pageStyle}}"></page-meta>
<view class="theme-root {{themeClass}}">
<view class="security-hero">
  <view class="hero-kicker">账号安全</view>
  <view class="hero-title">修改登录密码</view>
  <view class="hero-sub">建议使用不少于 10 位、包含字母和数字的密码。</view>
</view>

<view class="card">
  <view class="field">
    <view class="field-label">原密码</view>
    <input class="field-input" password cursor-spacing="40" placeholder="请输入原密码" value="{{oldPassword}}" data-field="oldPassword" bindinput="onInput" />
  </view>
  <view class="field">
    <view class="field-label">新密码</view>
    <input class="field-input" password cursor-spacing="40" placeholder="≥10位，须含字母和数字" value="{{newPassword}}" data-field="newPassword" bindinput="onInput" />
  </view>
  <view class="field">
    <view class="field-label">确认新密码</view>
    <input class="field-input" password cursor-spacing="40" placeholder="再次输入新密码" value="{{confirmPassword}}" data-field="confirmPassword" bindinput="onInput" />
  </view>
</view>

<view class="tip">修改成功后需要使用新密码重新登录</view>

<button class="btn-primary submit" hover-class="btn-hover" disabled="{{submitting}}" bindtap="onSubmit">确认修改</button>
</view>
