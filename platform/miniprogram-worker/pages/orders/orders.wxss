.orders-hero {
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.orders-hero::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.hero-kicker { color: rgba(255, 255, 255, 0.78); font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; letter-spacing: 2rpx; }
.hero-title { font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; margin-top: 4rpx; }
.hero-count {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(10rpx);
  border-radius: 999rpx;
  padding: 12rpx 26rpx;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 700;
}

/* 状态标签页（横向可滚动） */
.status-tabs {
  display: flex;
  white-space: nowrap;
  padding: 22rpx 24rpx 2rpx;
}
.status-tab {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  background: #FFFFFF;
  color: #64748B;
  font-size: calc(27rpx * var(--fs, 1));
  font-weight: 500;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.12);
}
.status-tab-on {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  font-weight: 700;
  border-color: transparent;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.22);
}
.status-tab-num {
  font-size: calc(22rpx * var(--fs, 1));
  background: rgba(15, 118, 110, 0.1);
  color: #0F766E;
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
  min-width: 28rpx;
  text-align: center;
}
.status-tab-on .status-tab-num {
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
}

.loading { text-align: center; color: #94A3B8; font-size: calc(25rpx * var(--fs, 1)); padding: 30rpx 0 10rpx; }

.order-list { padding: 20rpx 24rpx 180rpx; }

.card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.card-title { font-size: calc(31rpx * var(--fs, 1)); font-weight: 700; flex: 1; margin-right: 16rpx; color: #172033; line-height: 1.45; }
.status { font-size: calc(24rpx * var(--fs, 1)); padding: 8rpx 20rpx; border-radius: 999rpx; flex-shrink: 0; font-weight: 600; }
.status-working { background: #FFF7ED; color: #EA580C; }
.status-delivered { background: #FEF2F2; color: #DC2626; }
.status-settled { background: #ECFDF5; color: #059669; }
.status-cancelled { background: #F1F5F9; color: #64748B; }

.card-meta { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin-top: 8rpx; }
.card-price { color: #D97706; font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; margin-top: 12rpx; }
.card-row { color: #475569; font-size: calc(27rpx * var(--fs, 1)); margin-top: 14rpx; display: flex; align-items: center; }
.row-icon {
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 10rpx;
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(20rpx * var(--fs, 1));
  font-weight: 700;
  display: inline-block;
  text-align: center;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.row-icon.claim { background: #FFF7ED; color: #D97706; }
.card-row.deliver { background: #F7FAF9; border-radius: 14rpx; padding: 14rpx 18rpx; }
.deliver-struct { background: #F7FAF9; border-radius: 14rpx; padding: 12rpx 18rpx; margin-top: 14rpx; }
.ds-row { display: flex; gap: 16rpx; font-size: calc(26rpx * var(--fs, 1)); line-height: 1.8; }
.ds-k { color: #64748B; flex-shrink: 0; }
.ds-v { color: #172033; flex: 1; word-break: break-all; }
.t-dark .deliver-struct { background: rgba(148, 163, 184, 0.12); }
.t-dark .ds-v { color: #E5E7EB; }

.card-actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #EEF3F1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.btn { margin-left: 16rpx; }
.btn-primary-mini {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: calc(27rpx * var(--fs, 1));
  font-weight: 600;
  margin-left: 16rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 36rpx;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.22);
}
.btn-ghost { background: #FFFFFF; color: #0F766E; border: 1rpx solid #B6DAD4; border-radius: 999rpx; font-size: calc(27rpx * var(--fs, 1)); min-height: 72rpx; line-height: 72rpx; padding: 0 36rpx; }
.waiting { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); }
.done-tip { color: #059669; font-size: calc(26rpx * var(--fs, 1)); font-weight: 600; margin-right: auto; }
.card-actions { flex-wrap: wrap; row-gap: 14rpx; }

.card-row-flex { display: flex; justify-content: space-between; align-items: center; gap: 18rpx; }
.claim-link { color: #D97706; font-size: calc(27rpx * var(--fs, 1)); margin-top: 14rpx; display: flex; align-items: center; flex-shrink: 0; }
.card-row.files { display: flex; flex-wrap: wrap; gap: 12rpx; }
.file-chip {
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(25rpx * var(--fs, 1));
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}
.invoice-tip {
  margin-top: 16rpx;
  background: #FFFBEB;
  color: #B45309;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  font-size: calc(26rpx * var(--fs, 1));
  line-height: 1.6;
  border: 1rpx solid #FDE68A;
}

.dispute-link {
  color: #DC2626;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 600;
  margin-right: auto;
  min-height: 64rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 8rpx;
}

/* 派单邀约 */
.dispatch-list { padding: 20rpx 24rpx 0; }
.dispatch-head { font-size: calc(26rpx * var(--fs, 1)); font-weight: 700; color: #0F766E; margin: 8rpx 4rpx 14rpx; letter-spacing: 1rpx; }
.dispatch-card { border: 1rpx solid #B6DAD4; }
.dispatch-badge {
  font-size: calc(24rpx * var(--fs, 1));
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  font-weight: 600;
  background: #FFF7ED;
  color: #EA580C;
}

.type-chips { display: flex; flex-wrap: wrap; gap: 14rpx; }
.type-chip {
  background: #F4F8F7;
  color: #475569;
  font-size: calc(26rpx * var(--fs, 1));
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid transparent;
}
.type-chip-on {
  background: #E7F4F1;
  color: #0F766E;
  font-weight: 600;
  border-color: #14B8A6;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 18rpx;
  margin: 10rpx 0 26rpx;
}
.star { font-size: calc(60rpx * var(--fs, 1)); color: #E2E8F0; line-height: 1; }
.star-on { color: #F59E0B; }

.picker-box {
  background: #F4F8F7;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(29rpx * var(--fs, 1));
  color: #172033;
  min-height: 84rpx;
}

.modal-box .field { margin-bottom: 24rpx; }
.modal-box .field:last-of-type { margin-bottom: 4rpx; }

.t-dark .orders-hero {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%);
  box-shadow: none;
}

.t-dark .status-working {
  background: rgba(249, 115, 22, 0.16);
  color: #FDBA74;
}

.t-dark .status-delivered {
  background: rgba(239, 68, 68, 0.18);
  color: #FCA5A5;
}

.t-dark .status-settled {
  background: rgba(16, 185, 129, 0.16);
  color: #6EE7B7;
}

/* 派单邀约：标题提亮、待接受徽章改低饱和琥珀（原 #FFF7ED 浅底深色下露白） */
.t-dark .dispatch-head {
  color: #5EEAD4;
}
.t-dark .dispatch-badge {
  background: rgba(249, 115, 22, 0.16);
  color: #FDBA74;
}

.t-dark .card-meta,
.t-dark .waiting {
  color: #94A3B8;
}

.t-dark .card-title {
  color: #E5E7EB;
}

.t-dark .card-row {
  color: #CBD5E1;
}

.t-dark .row-icon {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
}

.t-dark .row-icon.claim {
  background: rgba(249, 115, 22, 0.16);
  color: #FDBA74;
}

.t-dark .card-row.deliver {
  background: #0F172A;
}

.t-dark .card-actions {
  border-top-color: #233149;
}

.t-dark .btn-primary-mini {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  box-shadow: none;
}

.t-dark .btn-ghost {
  background: #121C2B;
  color: #5EEAD4;
  border-color: #134E4A;
}

.t-dark .done-tip {
  color: #6EE7B7;
}

.t-dark .file-chip {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
}

.t-dark .invoice-tip {
  background: rgba(180, 83, 9, 0.18);
  color: #FCD34D;
  border-color: rgba(251, 191, 36, 0.26);
}

.t-dark .dispute-link {
  color: #FCA5A5;
}

.t-dark .type-chip {
  background: #0F172A;
  color: #CBD5E1;
}

.t-dark .type-chip-on {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
  border-color: #134E4A;
}

.t-dark .star {
  color: #334155;
}

.t-dark .star-on {
  color: #F59E0B;
}

.t-dark .picker-box {
  background: #0F172A;
  color: #F8FAFC;
}

.t-dark .status-tab {
  background: #121C2B;
  color: #94A3B8;
  border-color: #233149;
}

.t-dark .status-tab-on {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  box-shadow: none;
}

.t-dark .status-tab-num {
  background: rgba(94, 234, 212, 0.16);
  color: #5EEAD4;
}

.t-dark .status-tab-on .status-tab-num {
  background: rgba(255, 255, 255, 0.22);
  color: #FFFFFF;
}

.t-dark .status-cancelled {
  background: #1E293B;
  color: #94A3B8;
}

.t-dark .loading {
  color: #64748B;
}
