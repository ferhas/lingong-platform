page { padding: 24rpx; }

.bind-hero {
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  border-radius: 28rpx;
  padding: 36rpx 30rpx;
  color: #FFFFFF;
  margin-bottom: 22rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.bind-hero::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.hero-kicker { color: rgba(255, 255, 255, 0.76); font-size: calc(24rpx * var(--fs, 1)); font-weight: 600; }
.hero-title { font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; margin-top: 6rpx; }
.hero-sub { color: rgba(255, 255, 255, 0.84); font-size: calc(27rpx * var(--fs, 1)); line-height: 1.65; margin-top: 8rpx; }

.field { margin-bottom: 26rpx; }
.field:last-child { margin-bottom: 6rpx; }

.notice { color: #64748B; font-size: calc(26rpx * var(--fs, 1)); line-height: 1.7; margin: 8rpx 8rpx 28rpx; }
.submit { margin: 0 8rpx; }

.done-card {
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  border-radius: 28rpx;
  padding: 52rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.done-icon {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: calc(52rpx * var(--fs, 1));
  font-weight: 700;
  margin: 0 auto 20rpx;
}
.done-title { color: #FFFFFF; font-size: calc(34rpx * var(--fs, 1)); font-weight: 700; }
.done-sub { color: rgba(255, 255, 255, 0.88); font-size: calc(28rpx * var(--fs, 1)); margin-top: 12rpx; }

.tip-title { font-size: calc(28rpx * var(--fs, 1)); font-weight: 700; margin-bottom: 12rpx; }
.tip-body { color: #64748B; font-size: calc(27rpx * var(--fs, 1)); line-height: 1.8; }

.t-dark .bind-hero,
.t-dark .done-card {
  background: linear-gradient(130deg, #134E4A -10%, #0F766E 40%, #1D4ED8 130%);
  box-shadow: none;
}

.t-dark .notice,
.t-dark .tip-body {
  color: #94A3B8;
}
