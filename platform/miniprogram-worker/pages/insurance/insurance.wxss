.page-head {
  background: linear-gradient(150deg, #0F766E 0%, #0D9488 38%, #2563EB 135%);
  padding: 40rpx 32rpx 44rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 118, 110, 0.18);
}
.ph-title { color: #FFFFFF; font-size: calc(40rpx * var(--fs, 1)); font-weight: 800; }
.ph-sub { color: rgba(255, 255, 255, 0.84); font-size: calc(25rpx * var(--fs, 1)); margin-top: 10rpx; }

.tabs {
  display: flex;
  gap: 14rpx;
  margin: 24rpx 24rpx 0;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: calc(28rpx * var(--fs, 1));
  color: #64748B;
  background: #FFFFFF;
  border: 1rpx solid rgba(15, 118, 110, 0.1);
  border-radius: 999rpx;
  padding: 16rpx 0;
}
.tab-on {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 100%);
  color: #FFFFFF;
  font-weight: 600;
  border-color: transparent;
}

.wrap { padding: 22rpx 24rpx 60rpx; }
.row-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 16rpx; }
.p-task { font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; color: #172033; flex: 1; min-width: 0; }
.p-state, .c-state { flex-shrink: 0; font-size: calc(23rpx * var(--fs, 1)); font-weight: 600; border-radius: 999rpx; padding: 6rpx 18rpx; }
.state-on { color: #0F766E; background: #E0F2EF; }
.state-off { color: #94A3B8; background: #F1F5F4; }
.p-meta { color: #475569; font-size: calc(27rpx * var(--fs, 1)); margin-top: 14rpx; }
.p-no { color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); margin-top: 8rpx; }
.p-foot { margin-top: 18rpx; display: flex; justify-content: flex-end; }
.p-report {
  font-size: calc(26rpx * var(--fs, 1));
  color: #FFFFFF;
  background: linear-gradient(135deg, #D97706 0%, #EA580C 100%);
  border-radius: 999rpx;
  padding: 10rpx 30rpx;
  font-weight: 600;
}
.p-claimed { font-size: calc(25rpx * var(--fs, 1)); color: #94A3B8; }

.c-desc { color: #475569; font-size: calc(27rpx * var(--fs, 1)); margin-top: 14rpx; line-height: 1.7; }
.c-result { color: #0F766E; font-size: calc(26rpx * var(--fs, 1)); margin-top: 10rpx; }
.c-time { color: #8A99A8; font-size: calc(24rpx * var(--fs, 1)); margin-top: 10rpx; }
.c-reported { color: #B45309; background: #FEF3C7; }
.c-processing { color: #2563EB; background: #E5EDFF; }
.c-closed { color: #0F766E; background: #E0F2EF; }

.t-dark .page-head {
  background: linear-gradient(130deg, #134E4A -10%, #0F766E 40%, #1D4ED8 130%); box-shadow: none;
}

.t-dark .tab {
  background: #121C2B; border-color: #233149; color: #94A3B8;
}

.t-dark .tab-on {
  color: #FFFFFF;
}

.t-dark .p-task {
  color: #E5E7EB;
}

.t-dark .p-meta,
.t-dark .c-desc {
  color: #CBD5E1;
}

.t-dark .state-on {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}

.t-dark .state-off {
  color: #64748B; background: #1E293B;
}

.t-dark .c-reported {
  color: #FCD34D; background: rgba(180, 83, 9, 0.22);
}

.t-dark .c-processing {
  color: #93C5FD; background: rgba(37, 99, 235, 0.18);
}

.t-dark .c-closed {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}
