.tip {
  margin: 24rpx 24rpx 8rpx;
  background: linear-gradient(130deg, #14B8A6 -10%, #0F766E 40%, #2563EB 130%);
  color: #FFFFFF;
  border-radius: 28rpx;
  padding: 30rpx 28rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 36rpx rgba(15, 118, 110, 0.2);
}
.tip::after {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -90rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}
.tip-title {
  font-size: calc(34rpx * var(--fs, 1));
  font-weight: 800;
}
.tip-body {
  color: rgba(255, 255, 255, 0.84);
  font-size: calc(27rpx * var(--fs, 1));
  line-height: 1.65;
  margin-top: 8rpx;
}

.list { padding: 16rpx 24rpx 40rpx; }

.card-top { display: flex; justify-content: space-between; align-items: center; }
.card-title { font-size: calc(30rpx * var(--fs, 1)); font-weight: 700; color: #172033; }
.card-arrow { color: #0F766E; font-size: calc(27rpx * var(--fs, 1)); font-weight: 600; }
.card-meta { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); margin-top: 10rpx; }

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.sheet {
  background: #FFFFFF;
  width: 100%;
  border-radius: 24rpx 24rpx 0 0;
  padding: 36rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.sheet-title { font-size: calc(34rpx * var(--fs, 1)); font-weight: 800; text-align: center; color: #172033; }
.sheet-sub { color: #8A99A8; font-size: calc(26rpx * var(--fs, 1)); text-align: center; margin: 10rpx 0 20rpx; }
.sheet-body { flex: 1; max-height: 55vh; }
.sheet-content {
  display: block;
  font-size: calc(30rpx * var(--fs, 1));
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
}
.sheet-hash {
  margin-top: 24rpx;
  background: #F7FAF9;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
  color: #64748B;
  font-size: calc(24rpx * var(--fs, 1));
  word-break: break-all;
}
.sheet-close { margin-top: 24rpx; }

.t-dark .tip {
  background: linear-gradient(135deg, #0F5650 -20%, #103B43 50%, #15284A 120%);
  color: #FFFFFF;
  box-shadow: none;
}

.t-dark .card-arrow {
  color: #5EEAD4;
}

.t-dark .card-meta,
.t-dark .sheet-sub,
.t-dark .sheet-hash {
  color: #94A3B8;
}

.t-dark .sheet {
  background: #121C2B;
}

.t-dark .card-title,
.t-dark .sheet-title {
  color: #E5E7EB;
}

.t-dark .sheet-content {
  color: #CBD5E1;
}

.t-dark .sheet-hash {
  background: #0F172A;
}
