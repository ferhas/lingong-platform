.tc-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03), 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.tc-hover {
  transform: scale(0.985);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}
.tc-top { display: flex; justify-content: space-between; align-items: flex-start; }
.tc-title-wrap { flex: 1; min-width: 0; margin-right: 16rpx; }
.tc-title { font-size: calc(32rpx * var(--fs, 1)); font-weight: 700; color: #172033; line-height: 1.45; }
.tc-price { color: #EA8C00; font-size: calc(38rpx * var(--fs, 1)); font-weight: 800; flex-shrink: 0; }
.tc-symbol { font-size: calc(24rpx * var(--fs, 1)); margin-right: 2rpx; font-weight: 700; }
.tc-price-note { display: block; font-size: calc(18rpx * var(--fs, 1)); color: #9CA3AF; font-weight: 500; text-align: right; line-height: 1.2; }
.tc-tags { margin-top: 12rpx; display: flex; flex-wrap: wrap; gap: 10rpx; }
.tc-tag {
  font-size: calc(22rpx * var(--fs, 1));
  color: #0F766E;
  background: #E0F2EF;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}
.tc-tag-city { color: #2563EB; background: #E5EDFF; }
.tc-tag-trade { color: #B45309; background: #FEF3C7; }
.tc-unit { color: #8A99A8; font-size: calc(25rpx * var(--fs, 1)); margin-top: 12rpx; }
.tc-bottom {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F5F3;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}
.tc-company { color: #64748B; font-size: calc(26rpx * var(--fs, 1)); display: flex; align-items: center; min-width: 0; flex: 1; }
.tc-mark {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #14B8A6;
  box-shadow: 0 0 0 6rpx rgba(20, 184, 166, 0.14);
  margin-right: 14rpx;
  flex-shrink: 0;
}
.tc-applicants {
  color: #0F766E;
  font-size: calc(25rpx * var(--fs, 1));
  font-weight: 600;
  flex-shrink: 0;
  background: #E0F2EF;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}
.tc-status {
  flex-shrink: 0;
  font-size: calc(24rpx * var(--fs, 1));
  font-weight: 600;
  color: #0F766E;
  background: #E0F2EF;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}
.tc-status-off { color: #94A3B8; background: #F1F5F4; }

.t-dark .tc-card {
  background: #121C2B; border-color: #233149; box-shadow: none;
}

.t-dark .tc-title {
  color: #E5E7EB;
}

.t-dark .tc-price {
  color: #FBBF24;
}

.t-dark .tc-unit,
.t-dark .tc-company {
  color: #94A3B8;
}

.t-dark .tc-tag {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}

.t-dark .tc-tag-city {
  color: #93C5FD; background: rgba(37, 99, 235, 0.18);
}

.t-dark .tc-tag-trade {
  color: #FCD34D; background: rgba(180, 83, 9, 0.22);
}

.t-dark .tc-bottom {
  border-top-color: #233149;
}

.t-dark .tc-applicants,
.t-dark .tc-status {
  color: #5EEAD4; background: rgba(20, 184, 166, 0.14);
}

.t-dark .tc-status-off {
  color: #64748B; background: #1E293B;
}
