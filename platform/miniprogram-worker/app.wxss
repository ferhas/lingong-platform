page {
  background: linear-gradient(180deg, #EAF4F1 0%, #F3F7F6 360rpx, #F4F6FA 100%);
  font-size: calc(28rpx * var(--fs, 1));
  color: #172033;
  line-height: 1.6;
  min-height: 100vh;
  box-sizing: border-box;
}

view,
text,
input,
button,
scroll-view {
  box-sizing: border-box;
}

button::after {
  border: none;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.06);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03), 0 14rpx 36rpx rgba(15, 23, 42, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-hover {
  transform: scale(0.985);
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.04);
}

.empty {
  text-align: center;
  color: #64748B;
  font-size: calc(28rpx * var(--fs, 1));
  line-height: 1.7;
  padding: 100rpx 0 120rpx;
}

.empty::before {
  content: '○';
  display: block;
  width: 104rpx;
  height: 104rpx;
  line-height: 104rpx;
  margin: 0 auto 22rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #B8C7C3;
  font-size: calc(44rpx * var(--fs, 1));
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 48%, #2563EB 140%);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: calc(30rpx * var(--fs, 1));
  font-weight: 600;
  min-height: 88rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.26), 0 4rpx 10rpx rgba(15, 118, 110, 0.14);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.btn-hover {
  transform: translateY(2rpx) scale(0.99);
  box-shadow: 0 6rpx 14rpx rgba(15, 118, 110, 0.2);
}

.btn-primary[disabled] {
  background: #C2D2CF;
  color: #FFFFFF;
  box-shadow: none;
}

.btn-ghost {
  background: #FFFFFF;
  color: #0F766E;
  border: 1rpx solid #B6DAD4;
  border-radius: 999rpx;
  font-size: calc(28rpx * var(--fs, 1));
  min-height: 64rpx;
  transition: transform 0.15s ease;
}

.field-label {
  color: #64748B;
  font-size: calc(26rpx * var(--fs, 1));
  margin-bottom: 12rpx;
  font-weight: 500;
}

.field-input {
  width: 100%;
  background: #F4F8F7;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(30rpx * var(--fs, 1));
  color: #172033;
  min-height: 84rpx;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.section-kicker {
  color: #0F766E;
  font-size: calc(24rpx * var(--fs, 1));
  font-weight: 600;
  letter-spacing: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-mark {
  display: inline-block;
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #14B8A6 0%, #0F766E 100%);
  flex-shrink: 0;
  margin-right: 12rpx;
}

/* —— 通用弹窗 —— */
.modal-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
/* 键盘弹起时易遮挡确认按钮的弹窗，改为贴底展示（确认按钮始终在键盘上方） */
.modal-mask.modal-bottom { align-items: flex-end; }
.modal-box {
  width: 100%;
  max-height: 86vh;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  overflow-y: auto;
}
.modal-title {
  font-size: calc(33rpx * var(--fs, 1));
  font-weight: 800;
  color: #172033;
  text-align: center;
  margin-bottom: 8rpx;
}
.modal-sub {
  color: #8A99A8;
  font-size: calc(25rpx * var(--fs, 1));
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.6;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}
.modal-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: calc(29rpx * var(--fs, 1));
  font-weight: 600;
  min-height: 84rpx;
  line-height: 84rpx;
  padding: 0;
  text-align: center;
}
.modal-btn-plain {
  background: #F1F5F4;
  color: #475569;
}
.modal-btn-primary {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 48%, #2563EB 140%);
  color: #FFFFFF;
}
.modal-btn-primary[disabled] {
  background: #C2D2CF;
  color: #FFFFFF;
}

/* —— 短信验证码行 —— */
.sms-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.sms-row .field-input { flex: 1; }
.sms-btn {
  flex-shrink: 0;
  background: #E7F4F1;
  color: #0F766E;
  font-size: calc(26rpx * var(--fs, 1));
  font-weight: 600;
  border-radius: 18rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  padding: 0 26rpx;
  text-align: center;
}
.sms-btn.sms-disabled {
  background: #F1F5F4;
  color: #94A3B8;
}

/* —— 多行输入 —— */
.field-textarea {
  width: 100%;
  background: #F4F8F7;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  font-size: calc(29rpx * var(--fs, 1));
  color: #172033;
  min-height: 160rpx;
}

/*
 * 深色模式分两条路径：
 * 1) .sys-root —— 登录/协议等未接入「我的-深色模式」开关的页面，仍跟随系统（@media）。
 * 2) .t-dark   —— 已接入开关的页面，由根节点 <view class="theme-root {{themeClass}}"> 强制，
 *    可被设置切换并覆盖系统。页面底色/文字色另由 <page-meta page-style="{{pageStyle}}"> 注入。
 * 仅登录页用到的公共类（card/field-input/btn-primary）放进 .sys-root 媒体块即可，无需全量重复。
 */
@media (prefers-color-scheme: dark) {
  .sys-root .card {
    background: #121C2B;
    border-color: #233149;
    box-shadow: none;
  }

  .sys-root .field-input {
    background: #0F172A;
    border-color: transparent;
    color: #F8FAFC;
  }

  .sys-root .btn-primary {
    background: linear-gradient(135deg, #14B8A6 0%, #0F766E 48%, #1D4ED8 140%);
    box-shadow: none;
  }
}

.t-dark .card {
  background: #121C2B;
  border-color: #233149;
  box-shadow: none;
}

.t-dark .empty {
  color: #94A3B8;
}

.t-dark .empty::before {
  background: #121C2B;
  color: #475569;
  box-shadow: none;
}

.t-dark .btn-primary {
  background: linear-gradient(135deg, #14B8A6 0%, #0F766E 48%, #1D4ED8 140%);
  box-shadow: none;
}

.t-dark .btn-primary[disabled] {
  background: #334155;
  color: #94A3B8;
}

.t-dark .btn-ghost {
  background: #121C2B;
  color: #5EEAD4;
  border-color: #134E4A;
}

.t-dark .field-label {
  color: #CBD5E1;
}

.t-dark .field-input {
  background: #0F172A;
  border-color: transparent;
  color: #F8FAFC;
}

.t-dark .section-kicker {
  color: #5EEAD4;
}

.t-dark .title-mark {
  background: linear-gradient(180deg, #5EEAD4 0%, #14B8A6 100%);
}

.t-dark .modal-box {
  background: #121C2B;
}

.t-dark .modal-title {
  color: #E5E7EB;
}

.t-dark .modal-sub {
  color: #94A3B8;
}

.t-dark .modal-btn-plain {
  background: #1E293B;
  color: #CBD5E1;
}

.t-dark .modal-btn-primary[disabled] {
  background: #334155;
  color: #94A3B8;
}

.t-dark .sms-btn {
  background: rgba(20, 184, 166, 0.16);
  color: #5EEAD4;
}

.t-dark .sms-btn.sms-disabled {
  background: #1E293B;
  color: #64748B;
}

.t-dark .field-textarea {
  background: #0F172A;
  color: #F8FAFC;
}
