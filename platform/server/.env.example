PORT=3000
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=2h
# DB_PATH=D:/data/gigwork.db
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_PHONE=13800000001
ADMIN_PASSWORD=Admin@123456

# —— v5 商用化 ——
# 进程角色：all（默认，API+定时任务）/ api（仅API，可多实例）/ worker（仅定时任务，全局单实例）
# ROLE=all
# 三方回调验签密钥（生产必须独立设置）
WEBHOOK_SECRET=please-change-me-webhook-secret
# 身份证号等敏感凭据加密密钥（生产【强制】≥16位，缺失则拒绝启动；建议托管 KMS）
# SECRETS_KEY=please-change-me-secrets-key-at-least-32-bytes
# /metrics 抓取令牌（设置后 Prometheus 须携带 ?token= 或 Bearer）
# METRICS_TOKEN=
# 微信小程序登录凭据（生产【必须】配置，否则零工端微信登录 fail-closed 拒绝；缺失时仅开发态可用模拟登录）
# WX_APPID=
# WX_SECRET=
# 刷新令牌有效期（天，默认7；生产可缩短以降低令牌泄露窗口）
# REFRESH_TOKEN_DAYS=7
# 业务参数进程内缓存 TTL（毫秒，默认10000；多实例下控制配置变更的跨实例生效延迟）
# CONFIG_CACHE_TTL_MS=10000
